{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "server/dist",
    "rootDir": "server",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": false,
    "resolveJsonModule": true,
    "types": [],
    "typeRoots": []
  },
  "include": ["server/**/*.ts", "server/**/*.d.ts"]
}
