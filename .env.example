# Copie para `.env` / `.env.local` (não commitar)

# --- Front (Vite) — só o que pode ir ao browser ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Servidor / Edge (NÃO use prefixo VITE_) ---
# No Supabase Dashboard → Project Settings → Edge Functions → Secrets:
MISTRAL_API_KEY=
MEM0_API_KEY=
# GEMINI_API_KEY=

# Opcional
# MISTRAL_CORD_MODEL=mistral-small-latest
# MISTRAL_MODEL=mistral-small-latest

# Nota: MEM0_API_KEY e MISTRAL_API_KEY no .env local só ajudam se você
# rodar gateway Node local. O CORD em produção lê secrets do Supabase Edge.
