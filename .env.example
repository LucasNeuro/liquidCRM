# Supabase (preencha com o projeto real)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key

# Proxy AI local (fallback de dev). Em produção use Edge Functions.
VITE_AI_PROXY_URL=http://127.0.0.1:8787
# Opcional: override da base das functions (default = VITE_SUPABASE_URL/functions/v1)
# VITE_SUPABASE_FUNCTIONS_URL=https://xxxx.supabase.co/functions/v1

# Chaves só no servidor / Edge Function secrets (nunca VITE_)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
AI_PROXY_PORT=8787

# Cron indexação 18h (mesmo valor no Render Cron + Edge Function secret)
CRON_SECRET=
# EMBED_FUNCTION_URL=https://seu-projeto.supabase.co/functions/v1/embed-crm-batch
